deploy:
    name: Construir y Desplegar
    needs: sonarqube # Esto asegura que no se despliega si falla el Quality Gate
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Iniciar sesión en Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}
          
      - name: Construir y subir imagen Docker
        run: |
          docker build -t tu_usuario_dockerhub/mi-microservicio:latest .
          docker push tu_usuario_dockerhub/mi-microservicio:latest
          
      # Aquí iría el paso para conectarse a tu clúster de Kubernetes y aplicar los .yaml